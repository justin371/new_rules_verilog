#!/usr/bin/env bash
# This is a template for the bazel verilog_rtl_unit_test rule
# It is not intended to be run stand-alone
set -Eeuo pipefail

_unit_test_error=0
trap 'rc=$?; _unit_test_error=1; printf "ERROR: line %s exited %s: %s\n" "$LINENO" "$rc" "$BASH_COMMAND" >&2' ERR
_unit_test_on_exit() {
    local rc=$?
    if (( rc != 0 )); then
        (( _unit_test_error )) || printf "ERROR: unit-test script exited %s\n" "$rc" >&2
        if [[ "${SIMMER_KEEP_TERMINAL:-0}" == 1 && -t 0 ]]; then
            read -r -p "Press Enter to close this terminal..." || true
        fi
    fi
}
trap _unit_test_on_exit EXIT

generate_waves=0
launch_wave_viewer=0
remaining_args=()

while (( $# ))
do
    case $1 in
        "--waves" )
            generate_waves=1
            ;;
        "--launch" )
            launch_wave_viewer=1
            ;;
        *)
            remaining_args+=("$1")
            ;;
    esac
    shift
done

waves_render_args=()
if [ $generate_waves -eq 1 ]
then
    waves_render_args=(-input "{WAVES_RENDER_CMD_PATH}" -access r)
fi

wave_viewer_args=()
if [ $launch_wave_viewer -eq 1 ]
then
    waves_render_args=(-input "{WAVES_RENDER_CMD_PATH}" -access r)
    wave_viewer_args=({WAVE_VIEWER_COMMAND} waves.shm)
fi

{SIMULATOR_COMMAND} \
    -newsv \
    -plussv \
    -define TBV \
    -libext .sv \
    -libext .svh \
    -libext .v \
    -libext .vams \
    -enable_single_yvlib \
    -licqueue \
    -timescale 100fs/100fs \
    -vtimescale 100fs/100fs \
    -define TIMESCALE_STEP_FS=100 \
    -define TIMESCALE_PREC_FS=100 \
    {PRE_FLIST_ARGS}
    {FLISTS} \
        {TOP} \
    "${waves_render_args[@]}" \
    {POST_FLIST_ARGS} \
    "${remaining_args[@]}"
if (( launch_wave_viewer )); then
    "${wave_viewer_args[@]}"
fi
