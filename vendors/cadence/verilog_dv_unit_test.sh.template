#!/usr/bin/env bash
# This is a template for the bazel verilog_dv_unit_test rule
# It is not intended to be run stand-alone
set -Eeuo pipefail

_unit_test_error=0
trap 'rc=$?; _unit_test_error=1; printf "ERROR: line %s exited %s: %s\n" "$LINENO" "$rc" "$BASH_COMMAND" >&2' ERR
_unit_test_on_exit() {
    local rc=$?
    if (( rc != 0 )); then
        (( _unit_test_error )) || printf "ERROR: unit-test script exited %s\n" "$rc" >&2
        if [[ "${SIMMER_KEEP_TERMINAL:-0}" == 1 && -t 0 ]]; then
            read -r -p "Press Enter to close this terminal..." || true
        fi
    fi
}
trap _unit_test_on_exit EXIT

{SIMULATOR_COMMAND} \
    -libext .sv \
    -libext .svh \
    -libext .v \
    -libext .vams \
    -timescale 1ps/1ps \
    -vtimescale 1ps/1ps \
    -define TIMESCALE_STEP_FS=1000 \
    -define TIMESCALE_PREC_FS=1000 \
    -enable_single_yvlib \
    {DPI_LIBS} \
    {DEFAULT_SIM_OPTS} \
    {FLISTS} \
    {COMPILE_ARGS} \
    {RUN_ARGS} \
    "$@"
