#!/usr/bin/env bash
# Generated by verilog_rtl_unit_test for a VCS-backed SVUnit test.
set -Eeuo pipefail

trap 'rc=$?; printf "ERROR: VCS SVUnit script failed at line %s (exit %s): %s\n" "$LINENO" "$rc" "$BASH_COMMAND" >&2' ERR

remaining_args=()
while (( $# )); do
    case "$1" in
        --waves | --launch)
            # VCS one-step wave dumping is intentionally disabled.
            ;;
        *)
            remaining_args+=("$1")
            ;;
    esac
    shift
done

{SIMULATOR_COMMAND} runSVUnit \
    -s vcs \
    --no_abs_path_flist \
    --no_feedback \
    {SVUNIT_COMPILE_ARGS} \
    -o . \
    -d TBV \
    -d VCS \
    -d TIMESCALE_STEP_FS=100 \
    -d TIMESCALE_PREC_FS=100 \
    -c '-full64' \
    -c '-licqueue' \
    -c '+libext+.sv+.svh+.v+.vh+.vams+.vp+.svp' \
    -c '-timescale=100fs/100fs' \
    {SVUNIT_FLISTS} \
    {POST_FLIST_ARGS} \
    {SVUNIT_RUN_ARGS} \
    "${remaining_args[@]}"

grep -q "\[testrunner\]: PASSED" run.log
