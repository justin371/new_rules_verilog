#!/usr/bin/env bash
# Generated by verilog_rtl_unit_test for a VCS compile-and-run test.
set -Eeuo pipefail

_unit_test_error=0
trap 'rc=$?; _unit_test_error=1; printf "ERROR: line %s exited %s: %s\n" "$LINENO" "$rc" "$BASH_COMMAND" >&2' ERR
_unit_test_on_exit() {
    local rc=$?
    if [[ -n "${work_dir:-}" ]]; then
        rm -rf "$work_dir" || true
    fi
    if (( rc != 0 )); then
        (( _unit_test_error )) || printf "ERROR: unit-test script exited %s\n" "$rc" >&2
        if [[ "${SIMMER_KEEP_TERMINAL:-0}" == 1 && -t 0 ]]; then
            read -r -p "Press Enter to close this terminal..." || true
        fi
    fi
}
trap _unit_test_on_exit EXIT

generate_waves=0
launch_wave_viewer=0
remaining_args=()
while (( $# )); do
    case "$1" in
        --waves)
            generate_waves=1
            ;;
        --launch)
            generate_waves=1
            launch_wave_viewer=1
            ;;
        *)
            remaining_args+=("$1")
            ;;
    esac
    shift
done

work_dir="${TEST_TMPDIR:-${TMPDIR:-/tmp}}/rules_verilog_${BASHPID}"
mkdir -p "$work_dir"

# VCS one-step wave dumping is intentionally disabled for now. Keep these
# commands here so the established FSDB flow can be enabled after validation.
# compile_wave_args=(-debug_access+all -kdb)
# runtime_wave_args=(-ucli -do "{WAVES_RENDER_CMD_PATH}")

simv="$work_dir/simv"
{SIMULATOR_COMMAND} \
    -file "{COMPILE_ARGS_FILE}" \
    -Mdir="$work_dir/csrc" \
    -o "$simv"

{SIMULATOR_RUNNER} "$simv" "${remaining_args[@]}"

