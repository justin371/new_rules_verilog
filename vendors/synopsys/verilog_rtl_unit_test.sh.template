#!/usr/bin/env bash
# Generated by verilog_rtl_unit_test for a VCS compile-and-run test.
set -Eeuo pipefail

generate_waves=0
launch_wave_viewer=0
remaining_args=()
while (( $# )); do
    case "$1" in
        --waves)
            generate_waves=1
            ;;
        --launch)
            generate_waves=1
            launch_wave_viewer=1
            ;;
        *)
            remaining_args+=("$1")
            ;;
    esac
    shift
done

work_dir="${TEST_TMPDIR:-${TMPDIR:-/tmp}}/rules_verilog_${BASHPID}"
mkdir -p "$work_dir"
trap 'rm -rf "$work_dir"' EXIT

# VCS one-step wave dumping is intentionally disabled for now. Keep these
# commands here so the established FSDB flow can be enabled after validation.
# compile_wave_args=(-debug_access+all -kdb)
# runtime_wave_args=(-ucli -do "{WAVES_RENDER_CMD_PATH}")

simv="$work_dir/simv"
{SIMULATOR_COMMAND} \
    -file "{COMPILE_ARGS_FILE}" \
    -Mdir="$work_dir/csrc" \
    -o "$simv"

"$simv" "${remaining_args[@]}"

