#!/usr/bin/bash
# This is a template for the bazel verilog_rtl_unit_test rule
# It is not intended to be run stand-alone
set -e

generate_waves=0
launch_wave_viewer=0
remaining_args=()

while (( $# ))
do
    case $1 in
        "--waves" )
            generate_waves=1
            ;;
        "--launch" )
            launch_wave_viewer=1
            ;;
        *)
            remaining_args+=("$1")
            ;;
    esac
    shift
done

sim_run_cmd="-R"
if [ $generate_waves -eq 1 ] || [ $launch_wave_viewer -eq 1 ]
then
    sim_run_cmd="-R -ucli -do {WAVES_RENDER_CMD_PATH}"
fi

waves_launch_cmd=""
if [ $launch_wave_viewer -eq 1 ]
then
    waves_launch_cmd="{WAVE_VIEWER_COMMAND} -ssf waves.fsdb"
fi

{SIMULATOR_COMMAND} \
    -sverilog \
    +libext+.sv+.svh+.v+.vams \
    -licqueue \
    -timescale=100fs/100fs \
    +define+TBV \
    +define+TIMESCALE_STEP_FS=100 \
    +define+TIMESCALE_PREC_FS=100 \
    -kdb \
    -debug_access+all \
    {PRE_FLIST_ARGS}
    {FLISTS} \
        {TOP} \
    $sim_run_cmd \
    {POST_FLIST_ARGS} \
    "${remaining_args[@]}"
$waves_launch_cmd
