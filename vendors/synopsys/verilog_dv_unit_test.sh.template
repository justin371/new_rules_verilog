#!/usr/bin/env bash
# Generated by verilog_dv_unit_test for a VCS compile-and-run test.
set -Eeuo pipefail

_unit_test_error=0
trap 'rc=$?; _unit_test_error=1; printf "ERROR: line %s exited %s: %s\n" "$LINENO" "$rc" "$BASH_COMMAND" >&2' ERR
_unit_test_on_exit() {
    local rc=$?
    if [[ -n "${work_dir:-}" ]]; then
        rm -rf "$work_dir" || true
    fi
    if (( rc != 0 )); then
        (( _unit_test_error )) || printf "ERROR: unit-test script exited %s\n" "$rc" >&2
        if [[ "${SIMMER_KEEP_TERMINAL:-0}" == 1 && -t 0 ]]; then
            read -r -p "Press Enter to close this terminal..." || true
        fi
    fi
}
trap _unit_test_on_exit EXIT

work_dir="${TEST_TMPDIR:-${TMPDIR:-/tmp}}/rules_verilog_${BASHPID}"
mkdir -p "$work_dir"

simv="$work_dir/simv"
{SIMULATOR_COMMAND} \
    -full64 \
    -file "{COMPILE_ARGS_FILE}" \
    -Mdir="$work_dir/csrc" \
    -o "$simv"

{SIMULATOR_RUNNER} "$simv" \
    {DEFAULT_SIM_OPTS} \
    {DPI_LIBS} \
    {RUN_ARGS} \
    "$@"
