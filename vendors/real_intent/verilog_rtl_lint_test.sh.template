#!/usr/bin/env bash
# This is a template for the bazel verilog_rtl_lint_test rule
# It is not intended to be run stand-alone
set -Eeuo pipefail

trap 'rc=$?; printf "ERROR: lint script failed at line %s (exit %s): %s\n" "$LINENO" "$rc" "$BASH_COMMAND" >&2' ERR

mv lint.log lint.log.bak 2> /dev/null || true
{SIMULATOR_COMMAND} \
     -log lint.log -i {COMMAND_SCRIPT} -wait_license

./{LINT_PARSER} "$@"
