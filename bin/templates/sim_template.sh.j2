#!/usr/bin/env bash

set -Eeuo pipefail

trap 'rc=$?; printf "ERROR: simulation script failed at line %s (exit %s): %s\n" "$LINENO" "$rc" "$BASH_COMMAND" >&2' ERR

# Child processes use these stable paths instead of reconstructing Bazel runfile paths.
export PROJ_DIR={{ job.vcomper.rcfg.proj_dir|shell_quote }}
export SIMRESULTS={{ job.job_dir|shell_quote }}
export TEST_LOG_PATH={{ job._log_path|shell_quote }}
export SIM_WORK_DIR={{ sim_working_dir|shell_quote }}
export VIP_LOG_DIR="$SIMRESULTS"
export SVT_LOG_DIR="$SIMRESULTS"
OVERALL_EXIT_CODE=0

function record_simulation_duration {
    if [ -n "${SIMULATION_START_SECONDS:-}" ]; then
        printf '%%I:sim: Simulation duration: %s seconds\n' "$((SECONDS - SIMULATION_START_SECONDS))" >> "$TEST_LOG_PATH"
    fi
}

{%- if sockets %}
SOCKET_SIDECAR_GROUPS_FILE={{ job.sidecar_process_groups_path|shell_quote }}
: > "$SOCKET_SIDECAR_GROUPS_FILE"
SIMMER_SELF_STAT_FIELDS="$(sed 's/.*) //' "/proc/$$/stat")"
SIMMER_SESSION_ID="$(awk '{print $4}' <<< "$SIMMER_SELF_STAT_FIELDS")"

function socket_sidecar_group_is_owned {
    local sidecar_pid=$1
    local expected_start_time=$2
    if [ -r "/proc/$sidecar_pid/stat" ]; then
        local stat_fields
        stat_fields="$(sed 's/.*) //' "/proc/$sidecar_pid/stat")"
        local process_group
        local session_id
        local start_time
        process_group="$(awk '{print $3}' <<< "$stat_fields")"
        session_id="$(awk '{print $4}' <<< "$stat_fields")"
        start_time="$(awk '{print $20}' <<< "$stat_fields")"
        if [ "$process_group" = "$sidecar_pid" ] && \
           [ "$session_id" = "$SIMMER_SESSION_ID" ] && \
           [ "$start_time" = "$expected_start_time" ]; then
            return 0
        fi
        return 1
    fi
    local stat_path
    for stat_path in /proc/[0-9]*/stat; do
        [ -r "$stat_path" ] || continue
        local stat_fields
        stat_fields="$(sed 's/.*) //' "$stat_path")"
        local process_group
        local session_id
        process_group="$(awk '{print $3}' <<< "$stat_fields")"
        session_id="$(awk '{print $4}' <<< "$stat_fields")"
        if [ "$process_group" = "$sidecar_pid" ] && [ "$session_id" = "$SIMMER_SESSION_ID" ]; then
            return 0
        fi
    done
    return 1
}

function socket_sidecar_process_is_running {
    local sidecar_pid=$1
    local expected_start_time=$2
    [ -r "/proc/$sidecar_pid/stat" ] || return 1
    local stat_fields
    stat_fields="$(sed 's/.*) //' "/proc/$sidecar_pid/stat")"
    local process_state
    local start_time
    process_state="$(awk '{print $1}' <<< "$stat_fields")"
    start_time="$(awk '{print $20}' <<< "$stat_fields")"
    [ "$process_state" != "Z" ] && [ "$start_time" = "$expected_start_time" ]
}

function terminate_socket_sidecars {
    local sidecar_pid
    local sidecar_start_time
    while read -r sidecar_pid sidecar_start_time; do
        if socket_sidecar_group_is_owned "$sidecar_pid" "$sidecar_start_time"; then
            kill -CONT -- "-$sidecar_pid" 2>/dev/null || true
            kill -TERM -- "-$sidecar_pid" 2>/dev/null || true
        fi
    done < "$SOCKET_SIDECAR_GROUPS_FILE"
    if [ -s "$SOCKET_SIDECAR_GROUPS_FILE" ]; then
        sleep 1
    fi
    while read -r sidecar_pid sidecar_start_time; do
        if socket_sidecar_group_is_owned "$sidecar_pid" "$sidecar_start_time"; then
            kill -KILL -- "-$sidecar_pid" 2>/dev/null || true
        fi
        wait "$sidecar_pid" 2>/dev/null || true
    done < "$SOCKET_SIDECAR_GROUPS_FILE"
 {%- for _, _, socket_endpoint in sockets %}
    rm -f {{ socket_endpoint|shell_quote }}
 {%- endfor %}
    local sidecars_alive=0
    while read -r sidecar_pid sidecar_start_time; do
        if socket_sidecar_group_is_owned "$sidecar_pid" "$sidecar_start_time"; then
            sidecars_alive=1
        fi
    done < "$SOCKET_SIDECAR_GROUPS_FILE"
    if [ "$sidecars_alive" -eq 0 ]; then
        rm -f "$SOCKET_SIDECAR_GROUPS_FILE"
    fi
}
# The EXIT trap is the fallback for failures and signals before normal cleanup.
trap terminate_socket_sidecars EXIT
{%- endif %}

function run_test {
    declare -i overall_exit_code=0

 {%- if sockets %}
    cd "$PROJ_DIR"
 {%- endif %}
 {%- for socket_name, sidecar_command, socket_endpoint in sockets %}
    echo "--- Handling Socket: {{ socket_name }} ---"
    rm -f {{ socket_endpoint|shell_quote }}
    printf 'Spawning: %s\n' {{ sidecar_command|shell_quote }}
    # Job control gives each sidecar a process group, so cleanup also reaches
    # grandchildren launched by the configured command.
    set -m
    # The wrapper registers and stops itself before executing user code. This
    # closes the pause race between creating a process group and recording it.
    bash -c 'registry=$1; command=$2; stat_fields=$(sed "s/.*) //" "/proc/$$/stat"); start_time=$(awk "{print \$20}" <<< "$stat_fields"); printf "%s %s\n" "$$" "$start_time" >> "$registry"; kill -STOP "$$"; exec bash -c "$command"' \
        simmer-sidecar "$SOCKET_SIDECAR_GROUPS_FILE" {{ sidecar_command|shell_quote }} \
        > {{ (job.job_dir ~ '/' ~ socket_name ~ '.log')|shell_quote }} 2>&1 &
    declare SOCKET_SIDECAR_{{ loop.index }}_PID=$!
    set +m
    while ! awk -v pid="$SOCKET_SIDECAR_{{ loop.index }}_PID" '$1 == pid { found = 1 } END { exit !found }' "$SOCKET_SIDECAR_GROUPS_FILE"; do
        if ! kill -0 "$SOCKET_SIDECAR_{{ loop.index }}_PID" 2>/dev/null; then
            printf '%%E- ERROR: Socket wrapper %s exited before registration.\n' {{ socket_name|shell_quote }}
            overall_exit_code=1
            break
        fi
        sleep 0.01
    done
    kill -CONT -- "-$SOCKET_SIDECAR_{{ loop.index }}_PID" 2>/dev/null || true
    printf 'Socket %s started with PID %s (Log: %s)\n' {{ socket_name|shell_quote }} "$SOCKET_SIDECAR_{{ loop.index }}_PID" {{ (job.job_dir ~ '/' ~ socket_name ~ '.log')|shell_quote }}

    local socket_start_wait_seconds=0
    local socket_start_timeout_seconds=30
    while [ ! -e {{ socket_endpoint|shell_quote }} ]; do
        printf 'Waiting for %s (PID %s) to create %s...\n' {{ socket_name|shell_quote }} "$SOCKET_SIDECAR_{{ loop.index }}_PID" {{ socket_endpoint|shell_quote }}
        sleep 1
        if ! kill -0 "$SOCKET_SIDECAR_{{ loop.index }}_PID" 2>/dev/null; then
           printf '%%E- ERROR: Socket process %s (PID %s) exited prematurely without creating %s.\n' {{ socket_name|shell_quote }} "$SOCKET_SIDECAR_{{ loop.index }}_PID" {{ socket_endpoint|shell_quote }}
           printf 'Check log: %s\n' {{ (job.job_dir ~ '/' ~ socket_name ~ '.log')|shell_quote }}
           overall_exit_code=1
           break
        fi
        socket_start_wait_seconds=$((socket_start_wait_seconds + 1))
        if [ "$socket_start_wait_seconds" -ge "$socket_start_timeout_seconds" ]; then
            printf '%%E- ERROR: Timeout waiting for socket %s (PID %s) to create %s.\n' {{ socket_name|shell_quote }} "$SOCKET_SIDECAR_{{ loop.index }}_PID" {{ socket_endpoint|shell_quote }}
            overall_exit_code=1
            kill -TERM -- "-$SOCKET_SIDECAR_{{ loop.index }}_PID" 2>/dev/null || true
            break
        fi
    done
    if [ -e {{ socket_endpoint|shell_quote }} ]; then
        printf 'Socket file %s created.\n' {{ socket_endpoint|shell_quote }}
    fi
    echo "-------------------------------------"
 {%- endfor %}


 {%- if pre_run_cmd %}
    echo "--- Running Pre-Simulation Command ---"
    cd "$PROJ_DIR"
    echo "Executing: bazel run {{ pre_run_cmd }}"
    local pre_run_exit_code
    if bazel run {{ pre_run_cmd }} | tee {{ (job.job_dir ~ '/pre_run.stdout')|shell_quote }}; then
        pre_run_exit_code=0
    else
        pre_run_exit_code=$?
    fi
    echo "Pre-simulation command finished with exit code: $pre_run_exit_code"
    if [ $pre_run_exit_code -ne 0 ]; then
        echo "%E- ERROR: Pre-simulation command failed."
        overall_exit_code=1
    fi
    echo "-------------------------------------"
 {%- endif %}


    echo "--- Starting Main Simulation ---"
    echo "Host: $(uname -n)"
    echo "Time: $(date)"
    # Run from the per-test simulation directory so simulator, VIP, and debug
    # scratch logs stay with the test instead of leaking into bazel_runfiles_main.
    cd "$SIMRESULTS"

    mkdir -p {{ sim_working_dir|shell_quote }}
    ln -snf {{ job.vcomper.bazel_runfiles_main|shell_quote }} {{ (sim_working_dir ~ '/bazel_runfiles_main')|shell_quote }}
    cd {{ sim_working_dir|shell_quote }}
    echo "Current directory: $(pwd)"

    {% for pre_sim_command in pre_sim_commands %}
    local pre_sim_command_exit_code
    if eval {{ pre_sim_command|shell_quote }}; then
        pre_sim_command_exit_code=0
    else
        pre_sim_command_exit_code=$?
    fi
    if [ $pre_sim_command_exit_code -ne 0 ]; then
        echo "%E- ERROR: Pre-sim command failed: {{ pre_sim_command }}"
        overall_exit_code=1
    fi
    {% endfor %}

    if [ "$overall_exit_code" -ne 0 ]; then
        echo "%E- ERROR: Simulation preparation failed; skipping main simulation."
        OVERALL_EXIT_CODE=$overall_exit_code
        return
    fi

    # The timeout monitor starts here, after sidecar and pre-run setup complete.
    : > "$TEST_LOG_PATH"
    local SIMULATION_START_SECONDS=$SECONDS
    local simulation_exit_code
    # Commands with expected non-zero results stay inside conditionals so the
    # ERR trap reports only unexpected shell failures.
    if time {{ simulation_command }}; then
        simulation_exit_code=0
    else
        simulation_exit_code=$?
    fi
    record_simulation_duration
    echo "Simulation finished with exit code: $simulation_exit_code"
    if [ "$simulation_exit_code" -ne 0 ] && [ "$overall_exit_code" -eq 0 ]; then
        overall_exit_code=$simulation_exit_code
    fi

    {% for post_sim_command in post_sim_commands %}
    printf 'Executing post-sim command: %s\n' {{ post_sim_command|shell_quote }}
    local post_sim_command_exit_code
    if eval {{ post_sim_command|shell_quote }}; then
        post_sim_command_exit_code=0
    else
        post_sim_command_exit_code=$?
    fi
    if [ $post_sim_command_exit_code -ne 0 ]; then
        printf '%%W- WARNING: Post-sim command failed: %s\n' {{ post_sim_command|shell_quote }}
    fi
    {% endfor %}

    cd "$SIMRESULTS"
    echo "--- Main Simulation Finished ---"

    declare -i sidecar_failure_detected=0
 {%- for socket_name, _, socket_endpoint in sockets %}
    sidecar_pid_variable="SOCKET_SIDECAR_{{ loop.index }}_PID"
    if [ -n "${!sidecar_pid_variable:-}" ]; then
        local sidecar_pid="${!sidecar_pid_variable}"
        local sidecar_start_time
        local sidecar_stop_requested=0
        sidecar_start_time="$(awk -v pid="$sidecar_pid" '$1 == pid { print $2; exit }' "$SOCKET_SIDECAR_GROUPS_FILE")"
        echo "Waiting up to 5 seconds for socket {{ socket_name }} (PID $sidecar_pid) to exit..."
        local graceful_wait_seconds=0
        while socket_sidecar_group_is_owned "$sidecar_pid" "$sidecar_start_time" && \
              [ "$graceful_wait_seconds" -lt 5 ]; do
            sleep 1
            graceful_wait_seconds=$((graceful_wait_seconds + 1))
        done
        if socket_sidecar_group_is_owned "$sidecar_pid" "$sidecar_start_time"; then
            echo "Stopping socket {{ socket_name }} after simulation."
            if socket_sidecar_process_is_running "$sidecar_pid" "$sidecar_start_time"; then
                sidecar_stop_requested=1
            fi
            kill -CONT -- "-$sidecar_pid" 2>/dev/null || true
            kill -TERM -- "-$sidecar_pid" 2>/dev/null || true
            local termination_wait_seconds=0
            while socket_sidecar_group_is_owned "$sidecar_pid" "$sidecar_start_time" && \
                  [ "$termination_wait_seconds" -lt 5 ]; do
                sleep 1
                termination_wait_seconds=$((termination_wait_seconds + 1))
            done
            if socket_sidecar_group_is_owned "$sidecar_pid" "$sidecar_start_time"; then
                kill -KILL -- "-$sidecar_pid" 2>/dev/null || true
            fi
        fi
        local sidecar_exit_code
        if wait "$sidecar_pid"; then
            sidecar_exit_code=0
        else
            sidecar_exit_code=$?
        fi
        echo "Socket {{ socket_name }} exited with code: $sidecar_exit_code"
        local requested_signal_exit=0
        if [ "$sidecar_stop_requested" -ne 0 ] && \
           { [ "$sidecar_exit_code" -eq 137 ] || [ "$sidecar_exit_code" -eq 143 ]; }; then
            requested_signal_exit=1
        fi
        if [ "$sidecar_exit_code" -ne 0 ] && [ "$requested_signal_exit" -eq 0 ]; then
            echo "%E- ERROR: Socket process {{ socket_name }} (PID $sidecar_pid) returned non-zero exit code $sidecar_exit_code."
            echo "Check log: {{ job.job_dir }}/{{ socket_name }}.log"
            sidecar_failure_detected=1
        fi
    else
        echo "%W- WARNING: PID variable '$sidecar_pid_variable' not found for socket {{ socket_name }}. Cannot wait/check status."
    fi
    rm -f {{ socket_endpoint|shell_quote }}
 {% endfor %}
    if [ $sidecar_failure_detected -ne 0 ]; then
       echo "%E- At least one socket process failed."
       if [ $overall_exit_code -eq 0 ]; then overall_exit_code=1; fi
    fi

 {%- if options.skip_parse_sim_log == 0 %}
    cd "$SIMRESULTS"
    local log_check_python={{ check_test_python|shell_quote }}
    local log_check_script={{ check_test_path|shell_quote }}
    local simulation_log_file={{ job._log_path|shell_quote }}

    if [ -x "$log_check_python" ] && [ -f "$log_check_script" ] && [ -f "$simulation_log_file" ]; then
        local log_check_exit_code
        if "$log_check_python" "$log_check_script" "$simulation_log_file" {{ log_check_args }}; then
            log_check_exit_code=0
        else
            log_check_exit_code=$?
        fi
        # Preserve the simulator's exit code when both simulation and log checks fail.
        if [ $log_check_exit_code -ne 0 ]; then
            if [ $simulation_exit_code -eq 0 ]; then
                 overall_exit_code=$log_check_exit_code
            fi
        fi
    elif [ ! -x "$log_check_python" ]; then
        echo "%E- ERROR: Python interpreter not found or not executable at $log_check_python. Skipping log parsing."
        overall_exit_code=1
    elif [ ! -f "$log_check_script" ]; then
        echo "%E- ERROR: check_test script not found at $log_check_script. Skipping log parsing."
        overall_exit_code=1
    else
         echo "%E- ERROR: Simulation log file not found at $simulation_log_file. Cannot parse."
         if [ $simulation_exit_code -eq 0 ]; then overall_exit_code=1; fi
    fi
 {% endif %}

    OVERALL_EXIT_CODE=$overall_exit_code
}

function handle_termination_signal {
    echo "$(date): TRAPPED SIGNAL. Terminating script."
    record_simulation_duration
    for sidecar_pid in $(jobs -pr); do
        kill -TERM -- "-$sidecar_pid" 2>/dev/null || true
    done
    exit 1
}

trap "handle_termination_signal" TERM HUP INT QUIT USR1 USR2 PIPE

# Keep this call last so the generated script returns the accumulated test status.
run_test
exit "$OVERALL_EXIT_CODE"
