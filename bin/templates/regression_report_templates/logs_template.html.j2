{% extends "regression_report_templates/base_template.html.j2" %}
{% set dashboard_home_href = "../../../../index.html" %}

{% block title %}Logs | {{ bench_name }}{% endblock %}

{% block breadcrumbs %}
<a href="../../../../index.html">Projects</a><span>/</span>
<a href="../../../index.html">{{ project_name }}</a><span>/</span>
<a href="../../index.html">{{ bench_name }}</a><span>/</span><span>Logs</span>
{% endblock %}

{% block content %}
<div class="page-heading">
  <div>
    <h1>Logs</h1>
    <p class="subtitle">{{ project_name }} / {{ bench_name }}</p>
  </div>
</div>

{% if logs %}
<div class="table-wrap">
  <table class="table-compact">
    <caption>Regression log files</caption>
    <thead><tr><th scope="col">File</th></tr></thead>
    <tbody>
      {% for log in logs %}
      <tr><td class="cell-primary"><a href="{{ log|urlencode }}">{{ log }}</a></td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% else %}
<div class="empty-state">No log file is available.</div>
{% endif %}
{% endblock %}
