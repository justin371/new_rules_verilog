<!DOCTYPE html>
<html>
  <head>
    <title>Logs for {{project_name}}/{{bench_name}}</title>
  </head>
  <body>
    <h1>Logs for {{project_name}}/{{bench_name}}</h1>
    <br>
    <ul>
      {% for log in logs %}
      <li class="toctree-l1"><a class="reference internal" href="{{log|urlencode}}">{{log}}</a></li>
      {% endfor %}
    </ul>
  </body>
</html>
