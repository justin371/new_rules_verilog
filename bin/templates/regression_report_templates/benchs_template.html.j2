{% extends "regression_report_templates/base_template.html.j2" %}
{% set dashboard_home_href = "../index.html" %}

{% block title %}{{ project_name }} | Regression Dashboard{% endblock %}

{% block breadcrumbs %}
<a href="../index.html">Projects</a><span>/</span><span>{{ project_name }}</span>
{% endblock %}

{% block content %}
<div class="page-heading">
  <div>
    <h1>{{ project_name }}</h1>
    <p class="subtitle">Latest testbench results</p>
  </div>
</div>

{% set benches = bench_summaries|default([]) %}
{% if benches %}
<div class="table-wrap">
  <table>
    <caption>{{ project_name }} regression dashboard</caption>
    <thead>
      <tr>
        <th scope="col">Block</th>
        <th scope="col">Tests</th>
        <th scope="col">Passing</th>
        <th scope="col">Code Coverage</th>
        <th scope="col">Functional Coverage</th>
        <th scope="col">Passed</th>
        <th scope="col">Failed</th>
        <th scope="col">Skipped</th>
        <th scope="col">Last Run</th>
      </tr>
    </thead>
    <tbody>
      {% for item in benches %}
      {% set passrate = item.passrate|default(0, true)|float %}
      {% set code_available = item.cov_code is not none and item.cov_code is defined %}
      {% set functional_available = item.cov_func is not none and item.cov_func is defined %}
      {% set code_coverage = item.cov_code|float if code_available else 0 %}
      {% set functional_coverage = item.cov_func|float if functional_available else 0 %}
      <tr>
        <td class="cell-primary"><a href="{{ item.bench|urlencode }}/index.html">{{ item.bench }}</a></td>
        <td>{{ item.total|default(0, true) }}</td>
        <td class="{% if passrate >= 99.999 %}heat-good{% elif passrate >= 90 %}heat-warn{% else %}heat-bad{% endif %}">{{ "%.2f"|format(passrate) }}%</td>
        <td class="{% if not code_available %}heat-neutral{% elif code_coverage >= 90 %}heat-good{% elif code_coverage >= 75 %}heat-warn{% else %}heat-bad{% endif %}">{% if code_available %}{{ "%.2f"|format(code_coverage) }}%{% else %}N/A{% endif %}</td>
        <td class="{% if not functional_available %}heat-neutral{% elif functional_coverage >= 90 %}heat-good{% elif functional_coverage >= 75 %}heat-warn{% else %}heat-bad{% endif %}">{% if functional_available %}{{ "%.2f"|format(functional_coverage) }}%{% else %}N/A{% endif %}</td>
        <td>{{ item.passed|default(0, true) }}</td>
        <td class="{% if item.failed|default(0, true)|int > 0 %}heat-bad{% endif %}">{{ item.failed|default(0, true) }}</td>
        <td>{{ item.skipped|default(0, true) }}</td>
        <td class="cell-muted">{{ item.timestamp|default("No report", true) }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% else %}
<div class="empty-state">No regression result is available.</div>
{% endif %}
{% endblock %}
