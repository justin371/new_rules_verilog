{% extends "regression_report_templates/base_template.html.j2" %}
{% set dashboard_home_href = "index.html" %}

{% block title %}Projects | Regression Dashboard{% endblock %}

{% block content %}
<div class="page-heading">
  <div>
    <h1>Projects</h1>
    <p class="subtitle">Latest regression status by project and testbench</p>
  </div>
</div>

{% for project_name, benches in dashboard|default({})|dictsort %}
<section class="section" aria-labelledby="project-{{ loop.index }}">
  <div class="section-heading">
    <h2 id="project-{{ loop.index }}"><a href="{{ project_name|urlencode }}/index.html">{{ project_name }}</a></h2>
    <span class="section-note">{{ benches|length }} testbench{% if benches|length != 1 %}es{% endif %}</span>
  </div>
  {% if benches %}
  {% set coverage_benches = benches|selectattr('coverage_enabled')|list %}
  {% set show_coverage = coverage_benches|length == benches|length %}
  <div class="table-wrap">
    <table>
      <caption>{{ project_name }} latest regression results</caption>
      <thead>
        <tr>
          <th scope="col">Block</th>
          <th scope="col">Tests</th>
          <th scope="col">Passing</th>
          {% if show_coverage %}
          <th scope="col">Total Coverage</th>
          <th scope="col">Code Coverage</th>
          <th scope="col">Functional Coverage</th>
          {% endif %}
          <th scope="col">Failures</th>
          <th scope="col">Last Run</th>
        </tr>
      </thead>
      <tbody>
        {% for item in benches %}
        {% set passrate = item.passrate|default(0, true)|float %}
        {% set total_available = item.cov_total is not none and item.cov_total is defined %}
        {% set code_available = item.cov_code is not none and item.cov_code is defined %}
        {% set functional_available = item.cov_func is not none and item.cov_func is defined %}
        {% set total_coverage = item.cov_total|float if total_available else 0 %}
        {% set code_coverage = item.cov_code|float if code_available else 0 %}
        {% set functional_coverage = item.cov_func|float if functional_available else 0 %}
        <tr>
          <td class="cell-primary"><a href="{{ project_name|urlencode }}/{{ item.bench|urlencode }}/index.html">{{ item.bench }}</a></td>
          <td>{{ item.total|default(0, true) }}</td>
          <td class="{% if passrate >= 99.999 %}heat-good{% elif passrate >= 90 %}heat-warn{% else %}heat-bad{% endif %}">{{ "%.2f"|format(passrate) }}%</td>
          {% if show_coverage %}
          <td class="{% if not total_available %}heat-neutral{% elif total_coverage >= 90 %}heat-good{% elif total_coverage >= 75 %}heat-warn{% else %}heat-bad{% endif %}">{% if total_available %}{{ "%.2f"|format(total_coverage) }}%{% else %}N/A{% endif %}</td>
          <td class="{% if not code_available %}heat-neutral{% elif code_coverage >= 90 %}heat-good{% elif code_coverage >= 75 %}heat-warn{% else %}heat-bad{% endif %}">{% if code_available %}{{ "%.2f"|format(code_coverage) }}%{% else %}N/A{% endif %}</td>
          <td class="{% if not functional_available %}heat-neutral{% elif functional_coverage >= 90 %}heat-good{% elif functional_coverage >= 75 %}heat-warn{% else %}heat-bad{% endif %}">{% if functional_available %}{{ "%.2f"|format(functional_coverage) }}%{% else %}N/A{% endif %}</td>
          {% endif %}
          <td class="{% if item.failed|default(0, true)|int > 0 %}heat-bad{% else %}heat-good{% endif %}">{{ item.failed|default(0, true) }}</td>
          <td class="cell-muted">{{ item.timestamp|default("No report", true) }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% else %}
  <div class="empty-state">No regression result is available.</div>
  {% endif %}
</section>
{% else %}
<div class="empty-state">No project report is available.</div>
{% endfor %}
{% endblock %}
