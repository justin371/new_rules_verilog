{% extends "regression_report_templates/base_template.html.j2" %}
{% set dashboard_home_href = "index.html" %}

{% block title %}Projects | Regression Dashboard{% endblock %}

{% block content %}
<div class="page-heading">
  <div>
    <h1>Projects</h1>
    <p class="subtitle">Latest regression status by project and testbench</p>
  </div>
</div>

{% for project_name, benches in dashboard|default({})|dictsort %}
<section class="section" aria-labelledby="project-{{ loop.index }}">
  <div class="section-heading">
    <h2 id="project-{{ loop.index }}"><a href="{{ project_name|urlencode }}/index.html">{{ project_name }}</a></h2>
    <span class="section-note">{{ benches|length }} testbench{% if benches|length != 1 %}es{% endif %}</span>
  </div>
  {% if benches %}
  <div class="table-wrap">
    <table>
      <caption>{{ project_name }} latest regression results</caption>
      <thead>
        <tr>
          <th scope="col">Block</th>
          <th scope="col">Tests</th>
          <th scope="col">Passing</th>
          <th scope="col">Code Coverage</th>
          <th scope="col">Functional Coverage</th>
          <th scope="col">Failures</th>
          <th scope="col">Last Run</th>
        </tr>
      </thead>
      <tbody>
        {% for item in benches %}
        {% set passrate = item.passrate|default(0, true)|float %}
        {% set code_coverage = item.cov_code|default(0, true)|float %}
        {% set functional_coverage = item.cov_func|default(0, true)|float %}
        <tr>
          <td class="cell-primary"><a href="{{ project_name|urlencode }}/{{ item.bench|urlencode }}/index.html">{{ item.bench }}</a></td>
          <td>{{ item.total|default(0, true) }}</td>
          <td class="{% if passrate >= 99.999 %}heat-good{% elif passrate >= 90 %}heat-warn{% else %}heat-bad{% endif %}">{{ "%.2f"|format(passrate) }}%</td>
          <td class="{% if code_coverage >= 90 %}heat-good{% elif code_coverage >= 75 %}heat-warn{% elif code_coverage > 0 %}heat-bad{% else %}heat-neutral{% endif %}">{{ "%.2f"|format(code_coverage) }}%</td>
          <td class="{% if functional_coverage >= 90 %}heat-good{% elif functional_coverage >= 75 %}heat-warn{% elif functional_coverage > 0 %}heat-bad{% else %}heat-neutral{% endif %}">{{ "%.2f"|format(functional_coverage) }}%</td>
          <td class="{% if item.failed|default(0, true)|int > 0 %}heat-bad{% else %}heat-good{% endif %}">{{ item.failed|default(0, true) }}</td>
          <td class="cell-muted">{{ item.timestamp|default("No report", true) }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% else %}
  <div class="empty-state">No regression result is available.</div>
  {% endif %}
</section>
{% else %}
<div class="empty-state">No project report is available.</div>
{% endfor %}
{% endblock %}
