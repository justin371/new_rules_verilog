{% extends "regression_report_templates/base_template.html.j2" %}
{% set dashboard_home_href = "../../index.html" %}
{% set summary = latest_summary|default({}, true) %}

{% block title %}{{ bench_name }} | Regression Dashboard{% endblock %}

{% block breadcrumbs %}
<a href="../../index.html">Projects</a><span>/</span>
<a href="../index.html">{{ header.project_name }}</a><span>/</span><span>{{ bench_name }}</span>
{% endblock %}

{% block content %}
<div class="page-heading">
  <div>
    <h1>{{ bench_name }}</h1>
    <p class="subtitle">{{ header.simulator|upper }} regression at {{ header.time }}</p>
  </div>
  {% if summary.failed|default(0, true)|int > 0 %}
  <span class="status-text status-failed">Failed</span>
  {% elif summary.skipped|default(0, true)|int > 0 %}
  <span class="status-text status-skipped">Partial</span>
  {% else %}
  <span class="status-text status-passed">Passed</span>
  {% endif %}
</div>

{% set passrate = summary.passrate|default(0, true)|float %}
{% set total_available = summary.cov_total is not none and summary.cov_total is defined %}
{% set code_available = summary.cov_code is not none and summary.cov_code is defined %}
{% set functional_available = summary.cov_func is not none and summary.cov_func is defined %}
{% set total_coverage = summary.cov_total|float if total_available else 0 %}
{% set code_coverage = summary.cov_code|float if code_available else 0 %}
{% set functional_coverage = summary.cov_func|float if functional_available else 0 %}
<div class="metric-strip" aria-label="Latest regression summary">
  <div class="metric"><span class="metric-label">Tests</span><span class="metric-value">{{ summary.total|default(0, true) }}</span></div>
  <div class="metric"><span class="metric-label">Passed</span><span class="metric-value">{{ summary.passed|default(0, true) }}</span></div>
  <div class="metric"><span class="metric-label">Failed</span><span class="metric-value">{{ summary.failed|default(0, true) }}</span></div>
  <div class="metric"><span class="metric-label">Skipped</span><span class="metric-value">{{ summary.skipped|default(0, true) }}</span></div>
  <div class="metric {% if passrate >= 99.999 %}heat-good{% elif passrate >= 90 %}heat-warn{% else %}heat-bad{% endif %}"><span class="metric-label">Passing</span><span class="metric-value">{{ "%.2f"|format(passrate) }}%</span></div>
  <div class="metric {% if not total_available %}heat-neutral{% elif total_coverage >= 90 %}heat-good{% elif total_coverage >= 75 %}heat-warn{% else %}heat-bad{% endif %}"><span class="metric-label">Total Coverage</span><span class="metric-value">{% if total_available %}{{ "%.2f"|format(total_coverage) }}%{% else %}N/A{% endif %}</span></div>
  <div class="metric {% if not code_available %}heat-neutral{% elif code_coverage >= 90 %}heat-good{% elif code_coverage >= 75 %}heat-warn{% else %}heat-bad{% endif %}"><span class="metric-label">Code Coverage</span><span class="metric-value">{% if code_available %}{{ "%.2f"|format(code_coverage) }}%{% else %}N/A{% endif %}</span></div>
  <div class="metric {% if not functional_available %}heat-neutral{% elif functional_coverage >= 90 %}heat-good{% elif functional_coverage >= 75 %}heat-warn{% else %}heat-bad{% endif %}"><span class="metric-label">Functional Coverage</span><span class="metric-value">{% if functional_available %}{{ "%.2f"|format(functional_coverage) }}%{% else %}N/A{% endif %}</span></div>
</div>

<div class="metadata" aria-label="Run metadata">
  <div class="metadata-item"><span class="metadata-label">User</span><span class="metadata-value">{{ header.username }}</span></div>
  <div class="metadata-item"><span class="metadata-label">Branch</span><span class="metadata-value">{{ header.branch }}</span></div>
  <div class="metadata-item"><span class="metadata-label">Tag</span><span class="metadata-value">{{ header.tag|default("-", true) }}</span></div>
  <div class="metadata-item">
    <span class="metadata-label">Revision</span>
    <span class="metadata-value">{% if header.commit %}<a href="{{ header.commit }}" rel="noopener"><code>{{ header.revision }}</code></a>{% else %}<code>{{ header.revision }}</code>{% endif %}</span>
  </div>
  <div class="metadata-item"><span class="metadata-label">Simulator</span><span class="metadata-value">{{ header.simulator|upper }}</span></div>
  <div class="metadata-item"><span class="metadata-label">Run</span><span class="metadata-value"><code>{{ header.time }}</code></span></div>
</div>

{% if processed_category_stats %}
<section class="section" aria-labelledby="category-results">
  <div class="section-heading">
    <h2 id="category-results">Category Results</h2>
    <span class="section-note">All iterations must pass</span>
  </div>
  <div class="table-wrap">
    <table>
      <caption>Category regression results</caption>
      <thead>
        <tr>
          <th scope="col">Category</th>
          <th scope="col">Total Cases</th>
          <th scope="col">Executed</th>
          <th scope="col">Completion</th>
          <th scope="col">Passed</th>
          <th scope="col">Pass Rate</th>
        </tr>
      </thead>
      <tbody>
        {% for category, total, executed, completion_rate, passed, category_pass_rate in processed_category_stats %}
        {% set category_rate = category_pass_rate|replace('%', '')|float %}
        <tr>
          <td class="cell-primary">{{ category }}</td>
          <td>{{ total }}</td>
          <td>{{ executed }}</td>
          <td>{{ completion_rate }}</td>
          <td>{{ passed }}</td>
          <td class="{% if category_pass_rate == 'N/A' %}heat-neutral{% elif category_rate >= 99.999 %}heat-good{% elif category_rate >= 90 %}heat-warn{% else %}heat-bad{% endif %}">{{ category_pass_rate }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>
{% endif %}

<section class="section" aria-labelledby="test-results">
  <div class="section-heading">
    <h2 id="test-results">Test Results</h2>
  </div>
  <div class="table-wrap">
    <table>
      <caption>Test-level regression results</caption>
      <thead>
        <tr>
          <th scope="col">Bench</th>
          <th scope="col">Test</th>
          <th scope="col">Tag</th>
          <th scope="col">Max Time</th>
          <th scope="col">Passed</th>
          <th scope="col">Skipped</th>
          <th scope="col">Failed</th>
          <th scope="col">Total</th>
          <th scope="col">Pass Rate</th>
          <th scope="col">Logs</th>
        </tr>
      </thead>
      <tbody>
        {% for bench, test, tsim, passed, skipped, failed, total, row_pass_rate, logs, tags, logs_html in regression_details %}
        {% set row_rate = row_pass_rate|float %}
        <tr>
          <td class="cell-primary">{{ bench }}</td>
          <td class="align-left">{{ test }}</td>
          <td>{{ tags }}</td>
          <td>{{ tsim }}</td>
          <td>{{ passed }}</td>
          <td>{{ skipped }}</td>
          <td class="{% if failed|int > 0 %}heat-bad{% endif %}">{{ failed }}</td>
          <td>{{ total }}</td>
          <td class="{% if total|int == 0 %}heat-neutral{% elif row_rate >= 99.999 %}heat-good{% elif row_rate >= 90 %}heat-warn{% else %}heat-bad{% endif %}">{{ row_pass_rate }}%</td>
          <td>{% if logs_html %}<a href="logs/{{ logs_html|urlencode }}" target="_blank" rel="noopener">Open</a>{% endif %}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>

{% if cc_info or cf_info %}
<section class="section" aria-labelledby="coverage-details">
  <div class="section-heading"><h2 id="coverage-details">Coverage Details</h2></div>
  <div class="coverage-grid">
    {% if cc_info %}
    <div>
      <h3>Code Coverage</h3>
      <div class="table-wrap table-spaced">
        <table class="table-compact">
          <caption>Code coverage metrics</caption>
          <thead><tr>{% for key in cc_info %}<th scope="col">{{ key }}</th>{% endfor %}</tr></thead>
          <tbody><tr>{% for value in cc_info.values() %}<td>{{ value }}</td>{% endfor %}</tr></tbody>
        </table>
      </div>
    </div>
    {% endif %}
    {% if cf_info %}
    <div>
      <h3>Functional Coverage</h3>
      <div class="table-wrap table-spaced">
        <table class="table-compact">
          <caption>Functional coverage metrics</caption>
          <thead><tr>{% for key in cf_info %}<th scope="col">{{ key }}</th>{% endfor %}</tr></thead>
          <tbody><tr>{% for value in cf_info.values() %}<td>{{ value }}</td>{% endfor %}</tr></tbody>
        </table>
      </div>
    </div>
    {% endif %}
  </div>
</section>
{% endif %}

<section class="section" aria-labelledby="run-history">
  <div class="section-heading">
    <h2 id="run-history">Run History</h2>
    <span class="section-note">Latest 30 runs</span>
  </div>
  {% set history_rows = history|default([]) %}
  {% if history_rows %}
  <div class="table-wrap">
    <table>
      <caption>Regression run history</caption>
      <thead>
        <tr>
          <th scope="col">Run</th>
          <th scope="col">Tests</th>
          <th scope="col">Passing</th>
          <th scope="col">Total Coverage</th>
          <th scope="col">Code Coverage</th>
          <th scope="col">Functional Coverage</th>
          <th scope="col">Failed</th>
        </tr>
      </thead>
      <tbody>
        {% for item in history_rows %}
        {% set history_passrate = item.passrate|default(0, true)|float %}
        {% set history_total_available = item.cov_total is not none and item.cov_total is defined %}
        {% set history_code_available = item.cov_code is not none and item.cov_code is defined %}
        {% set history_functional_available = item.cov_func is not none and item.cov_func is defined %}
        <tr>
          <td class="cell-primary"><a href="{{ item.timestamp|urlencode }}.html"><code>{{ item.timestamp }}</code></a></td>
          <td>{{ item.total|default(0, true) }}</td>
          <td class="{% if history_passrate >= 99.999 %}heat-good{% elif history_passrate >= 90 %}heat-warn{% else %}heat-bad{% endif %}">{{ "%.2f"|format(history_passrate) }}%</td>
          <td>{% if history_total_available %}{{ "%.2f"|format(item.cov_total|float) }}%{% else %}N/A{% endif %}</td>
          <td>{% if history_code_available %}{{ "%.2f"|format(item.cov_code|float) }}%{% else %}N/A{% endif %}</td>
          <td>{% if history_functional_available %}{{ "%.2f"|format(item.cov_func|float) }}%{% else %}N/A{% endif %}</td>
          <td class="{% if item.failed|default(0, true)|int > 0 %}heat-bad{% endif %}">{{ item.failed|default(0, true) }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% else %}
  <div class="empty-state">No historical run is available.</div>
  {% endif %}
</section>
{% endblock %}
