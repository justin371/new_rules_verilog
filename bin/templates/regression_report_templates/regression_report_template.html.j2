  </script> 
  <script>
      function openLocalFolderOrFile(path) {
          window.open(
              path, 
              '_blank', 
              'width=1400,height=600,left=200,top=100,scrollbars=yes,resizable=yes'
          );
      }
  </script>
  <script>
      const ctx = document.getElementById('PassrateChart').getContext('2d');
      <!-- update chart -->
      const labels = {{regressions}};
      const data0 = {{passrate_list}};
      const data1 = {{q1_passrate_list}};
      <!-- update chart -->

      let myChart;
    
      function updateChart(dataCount) {
          const filteredLabels = labels.slice(-dataCount);
          const filteredData0 = data0.slice(-dataCount);
          const filteredData1 = data1.slice(-dataCount);

          if (myChart) {
              myChart.data.labels = filteredLabels;
              myChart.data.datasets[0].data = filteredData0;
              myChart.data.datasets[1].data = filteredData1;
              myChart.update();
          } else {
              myChart = new Chart(ctx, {
                  type: 'line',
                  data: {
                      labels: filteredLabels,
                      datasets: [
                          {
                              label: 'All Testcase Passrate',
                              data: filteredData0,
                              borderColor: 'rgba(75, 192, 192, 1)',
                              backgroundColor: 'rgba(75, 192, 192, 0.2)',
                              borderWidth: 2,
                              pointHoverRadius: 5,
                              pointRadius: 3,
                              fill: false,
                          },
                          {
                              label: 'Q1 Testcase Passrate',
                              data: filteredData1,
                              borderColor: 'rgba(255, 99, 132, 1)',
                              backgroundColor: 'rgba(255, 99, 132, 0.2)',
                              borderWidth: 2,
                              pointHoverRadius: 5,
                              pointRadius: 3,
                              fill: false,
                          },

                      ]
                  },
                  options: {
                      responsive: true,
                      scales: {
                          yAxes: [{
                              ticks: {
                                  beginAtZero: true
                              }
                          }],
                          xAxes: [{
                              scaleLabel: {
                                  display: true,
                                  labelString: 'Date'
                              }
                          }]
                      },
                      tooltips: {
                          enabled: true
                      }
                  }
              });
          }
      }

      const defaultDataCount = 30;
      updateChart(defaultDataCount);

      document.getElementById('dataCountSelect').addEventListener('change', (event) => {
          const dataCount = parseInt(event.target.value, 10);
          updateChart(dataCount);
      });

      ctx.canvas.addEventListener('click', (e) => {
          const points = myChart.getElementsAtEvent(e);
          if (points.length > 0) {
              const firstPoint = points[0];
              const labelIndex = firstPoint._index;
              if (labelIndex >= 0 && labelIndex < myChart.data.labels.length) {
                  const label = myChart.data.labels[labelIndex];
                  const pageUrl = `${label}.html`;
                  window.location.href = pageUrl;
              }
          }
      });
</script>
<script>
    const cellsTestcase = document.querySelectorAll('#Testcase td:nth-child(9)');
    const cellsccCov = document.querySelectorAll('#ccCOV td');
    const cellscfCov = document.querySelectorAll('#cfCOV td');
    cellsTestcase.forEach(cell => {
        const percentage = parseFloat(cell.textContent);
        if (percentage < 50) {
            cell.style.backgroundColor = '#FFCCCB';
        } else if (percentage >= 50 && percentage < 80) {
            cell.style.backgroundColor = '#FFFF99';
        } else if (percentage >= 80 && percentage < 100) {
            cell.style.backgroundColor = '#CCFFCC';
        } else if (percentage === 100) {
            cell.style.backgroundColor = '#99FF99';
        }
    });
    cellsccCov.forEach(cell => {
        const percentage = parseFloat(cell.textContent);
        if (percentage < 50) {
            cell.style.backgroundColor = '#FFCCCB';
        } else if (percentage >= 50 && percentage < 80) {
            cell.style.backgroundColor = '#FFFF99';
        } else if (percentage >= 80 && percentage < 100) {
            cell.style.backgroundColor = '#CCFFCC';
        } else if (percentage === 100) {
            cell.style.backgroundColor = '#99FF99';
        }
    });
    cellscfCov.forEach(cell => {
        const percentage = parseFloat(cell.textContent);
        if (percentage < 50) {
            cell.style.backgroundColor = '#FFCCCB';
        } else if (percentage >= 50 && percentage < 80) {
            cell.style.backgroundColor = '#FFFF99';
        } else if (percentage >= 80 && percentage < 100) {
            cell.style.backgroundColor = '#CCFFCC';
        } else if (percentage === 100) {
            cell.style.backgroundColor = '#99FF99';
        }
    });
</script>
</body>
