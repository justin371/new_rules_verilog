          <div role="main" class="document" itemscope="itemscope" itemtype="http://schema.org/Article">
            <div itemprop="articleBody">
              <section id="{{bench_name}}">
                <h1>{{bench_name}}<a class="headerlink" href="#{{header["project_name"]}}" title="Permalink to this heading"></a></h1>
                <div class="toctree-wrapper compound"></div>
                <div class="toctree-wrapper compound"></div>
                <h3>Regression Info</h3>
                <table class="docutils align-default">
                  <thead>
                    <tr>
                      <th align="center" style="border:1px solid #f2f2f2; padding:8px">User</th>
                      <th align="center" style="border:1px solid #f2f2f2; padding:8px">Time</th>
                      <th align="center" style="border:1px solid #f2f2f2; padding:8px">Git Revision</th>
                      <th align="center" style="border:1px solid #f2f2f2; padding:8px">Git Branch</th>
                      <th align="center" style="border:1px solid #f2f2f2; padding:8px">Simulator</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td align="center" style="border:1px solid #f2f2f2; padding:8px">{{header["username"]}}</td>
                      <td align="center" style="border:1px solid #f2f2f2; padding:8px">{{header["time"]}}</td>
                      <td align="center" style="border:1px solid #f2f2f2; padding:8px"><a href="{{header["commit"]}}"><code>{{header["revision"]}}</code></a></td>
                      <td align="center" style="border:1px solid #f2f2f2; padding:8px">{{header["branch"]}}</td>
                      <td align="center" style="border:1px solid #f2f2f2; padding:8px">{{header["simulator"]|upper}}</td>
                    </tr>
                  </tbody>
                </table>
                <br>
                <h3>Passrate Trend</h3>
                <select id="dataCountSelect">
                    <option value="30">30</option>
                    <option value="20">20</option>
                    <option value="10">10</option>
                </select>
                <canvas id="PassrateChart"></canvas>
                <div class="tooltip" id="tooltip"></div>
                <br>
                <h3>Q1 Test Results</h3>
                <table id="q1res" class="docutils align-default">
                  <thead>
                    <tr>
                      {% for key in q1_regression_details.keys() %}
                      <th align="center" style="background-color:#3D1067; color:white; padding-bottom:12px; padding-top:12px; text-transform:uppercase; border:1px solid #f2f2f2; padding:8px" bgcolor="#3D1067">{{key}}</th>
                      {% endfor %}
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td align="center" style="border:1px solid #f2f2f2; padding:8px">{{q1_regression_details["Total_Q1"]}}</td>
                      <td align="center" style="border:1px solid #f2f2f2; padding:8px">{{q1_regression_details["Pass_Q1"]}}</td>
                      {% set q1_passrate = q1_regression_details["Passrate_Q1"] | float %}
                      {% if q1_passrate == 100 %}
                        <td align="center"
                            style="border:1px solid #f2f2f2; padding:8px; background-color:#37b671">{{ q1_regression_details["Passrate_Q1"] }}</td>
                      {% elif q1_passrate >= 90 %}
                        <td align="center"
                            style="border:1px solid #f2f2f2; padding:8px; background-color:#c1d422">{{ q1_regression_details["Passrate_Q1"] }}</td>
                      {% else %}
                        <td align="center"
                            style="border:1px solid #f2f2f2; padding:8px; background-color:#be2e25">{{ q1_regression_details["Passrate_Q1"] }}</td>
                      {% endif %}
                    </tr>
                  </tbody>
                </table>
                <br>
                <h3>Test Results</h3>
                <table id="Testcase" class="docutils align-default">
                  <thead>
                    <tr>
                      <th align="center" style="background-color:#3D1067; color:white; padding-bottom:12px; padding-top:12px; text-transform:uppercase; border:1px solid #f2f2f2; padding:8px" bgcolor="#3D1067">Bench</th>
                      <th align="left" style="background-color:#3D1067; color:white; padding-bottom:12px; padding-top:12px; text-transform:uppercase; border:1px solid #f2f2f2; padding:8px" bgcolor="#3D1067">Tests</th>
                      <th align="center" style="background-color:#3D1067; color:white; padding-bottom:12px; padding-top:12px; text-transform:uppercase; border:1px solid #f2f2f2; padding:8px" bgcolor="#3D1067">Tag</th>
                      <th align="center" style="background-color:#3D1067; color:white; padding-bottom:12px; padding-top:12px; text-transform:uppercase; border:1px solid #f2f2f2; padding:8px" bgcolor="#3D1067">Max job time</th>
                      <th align="center" style="background-color:#3D1067; color:white; padding-bottom:12px; padding-top:12px; text-transform:uppercase; border:1px solid #f2f2f2; padding:8px" bgcolor="#3D1067">Passed</th>
                      <th align="center" style="background-color:#3D1067; color:white; padding-bottom:12px; padding-top:12px; text-transform:uppercase; border:1px solid #f2f2f2; padding:8px" bgcolor="#3D1067">Sikpped</th>
                      <th align="center" style="background-color:#3D1067; color:white; padding-bottom:12px; padding-top:12px; text-transform:uppercase; border:1px solid #f2f2f2; padding:8px" bgcolor="#3D1067">Failed</th>
                      <th align="center" style="background-color:#3D1067; color:white; padding-bottom:12px; padding-top:12px; text-transform:uppercase; border:1px solid #f2f2f2; padding:8px" bgcolor="#3D1067">Total</th>
                      <th align="center" style="background-color:#3D1067; color:white; padding-bottom:12px; padding-top:12px; text-transform:uppercase; border:1px solid #f2f2f2; padding:8px" bgcolor="#3D1067">Pass Rate</th>
                      <th align="center" style="background-color:#3D1067; color:white; padding-bottom:12px; padding-top:12px; text-transform:uppercase; border:1px solid #f2f2f2; padding:8px" bgcolor="#3D1067">Logs</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for bench, test, tsim, pass, skip, fail, total, pass_rate, logs, tags, logs_html in regression_details %}
                    <tr>
                      <td align="center" style="border:1px solid #f2f2f2; padding:8px">{{bench}}</td>
                      <td align="left" style="border:1px solid #f2f2f2; padding:8px">{{test}}</td>
                      <td align="center" style="border:1px solid #f2f2f2; padding:8px">{{tags}}</td>
                      <td align="center" style="border:1px solid #f2f2f2; padding:8px">{{tsim}}</td>
                      <td align="center" style="border:1px solid #f2f2f2; padding:8px">{{pass}}</td>
                      <td align="center" style="border:1px solid #f2f2f2; padding:8px">{{skip}}</td>
                      <td align="center" style="border:1px solid #f2f2f2; padding:8px">{{fail}}</td>
                      <td align="center" style="border:1px solid #f2f2f2; padding:8px">{{total}}</td>
                      {% if pass_rate|float == 100 %}
                      <td align="center" style="border:1px solid #f2f2f2; padding:8px; background-color:#37b671">{{pass_rate}}</td>
                      {% elif pass_rate|float >= 90 %}
                      <td align="center" style="border:1px solid #f2f2f2; padding:8px; background-color:#c1d422">{{pass_rate}}</td>
                      {% else %}
                      <td align="center" style="border:1px solid #f2f2f2; padding:8px;background-color:#be2e25">{{pass_rate}}</td>
                      {% endif %}
                      {% if logs != "" %}
                      <td align="center" style="border:1px solid #f2f2f2; padding:8px; border-top: 1px solid #f2f2f2"><button onclick="openLocalFolderOrFile('logs/{{logs_html}}')">logs</botton></td>
                      {% else %}
                      <td align="center" style="border:1px solid #f2f2f2; padding:8px"></td>
                      {% endif %}
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
                <br>
                {% if cc_info %}
                <h3>Code Coverage Results</h3>
                <table id="ccCOV" class="docutils align-default">
                  <thead>
                    <tr>
                      {% for key in cc_info.keys() %}
                      <th align="center" style="background-color:#3D1067; color:white; padding-bottom:12px; padding-top:12px; text-transform:uppercase; border:1px solid #f2f2f2; padding:8px" bgcolor="#3D1067">{{key}}</th>
                      {% endfor %}
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                    {% for value in cc_info.values() %}
                      <td align="center" style="border:1px solid #f2f2f2; padding:8px">{{value}}</td>
                    {% endfor %}
                    </tr>
                  </tbody>
                </table>
                <br>
                {% endif %}
                {% if cf_info %}
                <h3>Functional Coverage Results</h3>
                <table id="cfCOV" class="docutils align-default">
                  <thead>
                    <tr>
                      {% for key in cf_info.keys() %}
                      <th align="center" style="background-color:#3D1067; color:white; padding-bottom:12px; padding-top:12px; text-transform:uppercase; border:1px solid #f2f2f2; padding:8px" bgcolor="#3D1067">{{key}}</th>
                      {% endfor %}
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                    {% for value in cf_info.values() %}
                      <td align="center" style="border:1px solid #f2f2f2; padding:8px">{{value}}</td>
                    {% endfor %}
                    </tr>
                  </tbody>
                </table>
                <br>
                {% endif %}
                <h3>Past Result </h3>
                <ul>
                  <li><a href="index.html">Latest</a></li>
                  <!-- update past result -->
                  {% set reversed_regression_list = regressions|reverse %}
                  {% set reversed_passrate_list = passrate_list|reverse %}
                  {% set reversed_cov_code_list = cov_code_list|reverse %}
                  {% set reversed_cov_func_list = cov_func_list|reverse %}
                  {% set zippped = reversed_regression_list|zip(reversed_passrate_list, reversed_cov_code_list, reversed_cov_func_list) %}
                  {% set zip_list = zippped|list %}
                  {% for time, pr, cc, cf in zip_list[1:] %}
                  <li><a href="{{time}}.html">{{time}}_{{pr}}%_{{cc}}_{{cf}}</a></li>
                  {% endfor %}
                  <!-- update past result -->
                </ul>
              </section>
            </div>
          </div>
          <footer>
            <div class="rst-footer-buttons" role="navigation" aria-label="Footer">
              <a href="../index.html" class="btn btn-neutral float-left" title="{{header["project_name"]|capitalize}}" accesskey="p" rel="prev"><span class="fa fa-arrow-circle-left" aria-hidden="true"></span> Previous</a>
