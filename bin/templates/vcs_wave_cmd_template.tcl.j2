# UCLI returns the actual dump file ID; do not assume a fixed identifier.
set wave_fid [dump -file {{ waves_db|tcl_quote }} -type FSDB]
# Glitch capture is configured per open FSDB file, while +fsdb+force is a simv option.
dump -glitch on -fid $wave_fid
{% set fsdb_hierarchy_depth = 0 if options.wave_depth == 999 else options.wave_depth -%}
{% for probe in options.probes -%}
# simmer's sentinel depth 999 maps to UCLI depth 0, meaning all descendants.
dump -add {{ probe }} -fid $wave_fid -depth {{ fsdb_hierarchy_depth }} -aggregates -fsdb_opt +packedmda+struct+parameter
{% endfor -%}
{% if options.wave_start > 0 -%}
dump -disable -fid $wave_fid
stop -absolute {{ options.wave_start }}ns -command {dump -enable -fid $wave_fid} -continue
{% else -%}
dump -enable -fid $wave_fid
{% endif -%}
{% if options.wave_end != 99999999 -%}
stop -absolute {{ options.wave_end }}ns -command {dump -disable -fid $wave_fid; dump -flush $wave_fid} -continue
{% endif -%}
run
dump -flush $wave_fid
# UCLI closes all open dump files because dump -close does not accept a file ID.
dump -close
exit
