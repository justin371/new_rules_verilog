#!/usr/bin/env bash
set -Eeuo pipefail

trap 'rc=$?; printf "ERROR: Xcelium compile failed at line %s (exit %s): %s\n" "$LINENO" "$rc" "$BASH_COMMAND" >&2' ERR

cd {{ bazel_runfiles_main|shell_quote }}
runmod -t xrun -- \
  {% if options.msie_prim is none -%}
  -xmlibdirname {{ VCOMP_DIR|shell_quote }} \
  {% endif -%}
  {% for define in additional_defines -%}
    -define {{ define|shell_quote }} \
  {% endfor -%}
  {% if options.mce -%}
    -mce \
    -mce_newperf \
    -mce_build_cpu_configuration {{ options.mce_build_cfg }} \
    -mce_build_thread_count {{ options.mce_build_count }} \
    -mce_split_max_size {{ options.mce_split_max_size }} \
  {% endif -%}
  {% if xprop_cmd is not none -%}
    {{ xprop_cmd }} \
  {% endif -%}

  {% if debug_mode in ["waves", "gui"] -%}
    -debug_opts verisium_pp \
  {% endif -%}

  {% if options.msie_href -%}
    -primtop {{ msie_primary_top|shell_quote }} -genhref {{ msie_href_file|shell_quote }} \
  {% endif -%}
  {% if options.msie_prim -%}
    -mkprimsnap -top {{ msie_primary_top|shell_quote }} -snapshot {{ msie_primary_name|shell_quote }} \
    -href {{ msie_href_file|shell_quote }} \
    -xmlibdirname {{ VCOMP_DIR|shell_quote }} \
    {% for extern_file in msie_extern_files -%}
    {{ extern_file|shell_quote }} \
    {% endfor -%}
  {% endif -%}
  {% if options.msie_incr -%}
    -primname {{ msie_primary_name|shell_quote }} \
    -primlibdir {{ msie_primary_dir|shell_quote }} \
  {% endif -%}    
  {% if options.msie -%}
    -primtop {{ msie_primary_top|shell_quote }} \
  {% endif -%}

  {% if options.compile_args_file -%}
    -file {{ options.compile_args_file|shell_quote }} \
  {% endif -%}

  -f {{ bazel_compile_args|shell_quote }} \
  {% if cov_opts -%}
    {{ cov_opts }} \
  {% endif -%}
  -l {{ (VCOMP_DIR ~ '/cmp.log')|shell_quote }}
