#!/usr/bin/env bash

set -euo pipefail

# --- Dynamic values passed from Python ---
# job_dir (passed for informational purposes in the script)
# wave_file_path
# bazel_runfiles_dir
# wave_view_command

echo "Preparing to open wave file..."
echo "Job directory: {{ job_dir }}"
echo "Wave file: {{ wave_file_path }}"
echo "Runfiles directory: {{ bazel_runfiles_dir }}"
echo "Target run directory: {{ job_dir }}"

# Check if bazel_runfiles_main directory exists
if [ ! -d "{{ bazel_runfiles_dir }}" ]; then
    echo "Error: Directory {{ bazel_runfiles_dir }} does not exist."
    echo "Please ensure your bazel runfiles are correctly set up in the job directory."
    exit 1
fi

echo "Changing directory to {{ job_dir }}"
cd "{{ job_dir }}"

WAVE_VIEW_COMMAND={{ wave_view_command }}

if [ -n "${SIMMER_WAVE_LAUNCHER:-}" ]; then
    echo "Executing: ${SIMMER_WAVE_LAUNCHER} ${WAVE_VIEW_COMMAND}"
    eval "${SIMMER_WAVE_LAUNCHER} ${WAVE_VIEW_COMMAND}"
else
    echo "Executing: ${WAVE_VIEW_COMMAND}"
    eval "${WAVE_VIEW_COMMAND}"
fi

echo "Returning to previous directory."
cd - > /dev/null # Suppress output of 'cd -'

echo "Wave viewer exited."
