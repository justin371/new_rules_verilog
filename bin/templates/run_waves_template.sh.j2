#!/usr/bin/env bash

set -Eeuo pipefail

trap 'rc=$?; printf "ERROR: wave viewer script failed at line %s (exit %s): %s\n" "$LINENO" "$rc" "$BASH_COMMAND" >&2' ERR

# --- Dynamic values passed from Python ---
# job_dir (passed for informational purposes in the script)
# wave_file_path
# bazel_runfiles_dir
# wave_view_command

echo "Preparing to open wave file..."
printf 'Job directory: %s\n' {{ job_dir|shell_quote }}
printf 'Wave file: %s\n' {{ wave_file_path|shell_quote }}
printf 'Runfiles directory: %s\n' {{ bazel_runfiles_dir|shell_quote }}
printf 'Target run directory: %s\n' {{ job_dir|shell_quote }}

# Check if bazel_runfiles_main directory exists
if [ ! -d {{ bazel_runfiles_dir|shell_quote }} ]; then
    printf 'Error: Directory %s does not exist.\n' {{ bazel_runfiles_dir|shell_quote }}
    echo "Please ensure your bazel runfiles are correctly set up in the job directory."
    exit 1
fi

printf 'Changing directory to %s\n' {{ job_dir|shell_quote }}
cd {{ job_dir|shell_quote }}

WAVE_VIEW_COMMAND={{ wave_view_command }}
mapfile -t WAVE_VIEW_ARGV <<< "${WAVE_VIEW_COMMAND}"
if [[ -z "${WAVE_VIEW_ARGV[0]:-}" ]]; then
    echo "Error: Wave viewer command is empty." >&2
    exit 1
fi

if [ -n "${SIMMER_WAVE_LAUNCHER:-}" ]; then
    # Parse shell-style quoting without evaluating operators, substitutions, or
    # expansions. Each parsed token is prepended literally.
    if command -v python3.12 >/dev/null 2>&1; then
        WAVE_LAUNCHER_PYTHON=python3.12
    elif command -v python3 >/dev/null 2>&1; then
        WAVE_LAUNCHER_PYTHON=python3
    else
        echo "Error: Python 3 is required to parse SIMMER_WAVE_LAUNCHER." >&2
        exit 1
    fi
    mapfile -d '' -t WAVE_LAUNCHER_ARGV < <(
        "${WAVE_LAUNCHER_PYTHON}" -c \
            'import os, shlex, sys; sys.stdout.buffer.write(b"".join(os.fsencode(arg) + b"\0" for arg in shlex.split(sys.argv[1])))' \
            "${SIMMER_WAVE_LAUNCHER}"
    )
    if [[ -z "${WAVE_LAUNCHER_ARGV[0]:-}" ]]; then
        echo "Error: SIMMER_WAVE_LAUNCHER is empty or has invalid quoting." >&2
        exit 1
    fi
    printf 'Executing:'
    printf ' %q' "${WAVE_LAUNCHER_ARGV[@]}" "${WAVE_VIEW_ARGV[@]}"
    printf '\n'
    "${WAVE_LAUNCHER_ARGV[@]}" "${WAVE_VIEW_ARGV[@]}"
else
    printf 'Executing:'
    printf ' %q' "${WAVE_VIEW_ARGV[@]}"
    printf '\n'
    "${WAVE_VIEW_ARGV[@]}"
fi

echo "Returning to previous directory."
cd - > /dev/null # Suppress output of 'cd -'

echo "Wave viewer exited."
