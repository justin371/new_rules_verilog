#!/usr/bin/env bash

# Exit on any error
set -e

# --- Configuration (can be set here or passed as variables) ---
BSUB_COMMAND_PATH="/global/tools/lsf/10.1/linux3.10-glibc2.17-x86_64/bin/bsub"
# XRUN_BASE_COMMAND includes options common to all wave dump viewing
XRUN_BASE_COMMAND="runmod xrun -- verisium -64bit"
BSUB_OPTIONS="-I -q syn" # Common bsub options

# --- Dynamic values passed from Python ---
# job_dir (passed for informational purposes in the script)
# wave_file_path
# bazel_runfiles_dir

echo "Preparing to run xrun with wave file..."
echo "Job directory: {{ job_dir }}"
echo "Wave file: {{ wave_file_path }}"
echo "Target run directory: {{ bazel_runfiles_dir }}"

# Check if bazel_runfiles_main directory exists
if [ ! -d "{{ bazel_runfiles_dir }}" ]; then
    echo "Error: Directory {{ bazel_runfiles_dir }} does not exist."
    echo "Please ensure your bazel runfiles are correctly set up in the job directory."
    exit 1
fi

echo "Changing directory to {{ bazel_runfiles_dir }}"
cd "{{ bazel_runfiles_dir }}"

# Construct the full command
# Note: Quoting "{{ wave_file_path }}" is important for paths with spaces
FULL_XRUN_COMMAND="${XRUN_BASE_COMMAND} -db \"{{ wave_file_path }}\""

echo "Executing bsub command:"
echo "${BSUB_COMMAND_PATH} ${BSUB_OPTIONS} ${FULL_XRUN_COMMAND}"
${BSUB_COMMAND_PATH} ${BSUB_OPTIONS} ${FULL_XRUN_COMMAND}

echo "Returning to previous directory."
cd - > /dev/null # Suppress output of 'cd -'

echo "Script finished. xrun submitted via bsub."
