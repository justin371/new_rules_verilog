#!/usr/bin/env bash

mkdir -p {{ VCOMP_DIR }}/csrc && \

cd {{ bazel_runfiles_main }} && \

{{ vcs_runner }} vcs \
  -full64 \
  -Mdir={{ VCOMP_DIR }}/csrc \
  -Mlib={{ VCOMP_DIR }}/csrc \
  -p1800_macro_expansion \
  {% if options.fgp is not none -%}
    -fgp \
  {% endif -%}
  {% if options.vcs_profile -%}
    -pcmakeprof -reportstats \
  {% endif -%}
  {% if options.dtl -%}
    -dir={{ VCOMP_DIR }}/dtl_static \
    -enable_dynamic_tb \
  {% endif -%}

  {% if options.compile_args_file -%}
    -file {{ options.compile_args_file }} \
  {% endif -%}

  {% if options.vso -%}
    -vso cso \
    -vso_opts buildname={{ vso_build_name }} \
    -vso_opts workdir={{ vso_workdir }} \
  {% endif -%}

  -file {{ bazel_compile_args }} \
  {% for define in additional_defines -%}
    +define+{{ define }} \
  {% endfor -%}
  {% if debug_mode == "waves" -%}
    {% if options.dtl -%}
      -kdb=common_elab \
    {% else -%}
      -kdb \
    {% endif -%}
    -debug_access+all+designer+simctrl \
    +vpi \
    +define+UVM_VERDI_COMPWAVE \
  {% endif -%}
  {% if debug_mode == "gui" -%}
    -kdb \
    -debug_access+all+reverse \
    +vpi \
  {% endif -%}
  {% if options.xprop_was_explicit and xprop_cmd -%}
    {{ xprop_cmd }} \
  {% endif -%}
  {% if cov_opts -%}
    {{ cov_opts }} \
  {% endif -%}
  {% if options.smartlog or options.waves is not none or options.gui -%}
    -sml \
  {% endif -%}
  -l {{ VCOMP_DIR }}/cmp.log \
  -o {{ VCOMP_DIR }}/simv
