#!/usr/bin/env bash

cd {{ bazel_runfiles_main }} && \

runmod vcs -- vcs \
  -full64 \
  -Mdir={{ VCOMP_DIR }}/csrc \
  -Mlib={{ VCOMP_DIR }}/csrc \
  -p1800_macro_expansion \
  {% if options.fgp is not none -%}
    -fgp \
  {% endif -%}
  {% if options.vcs_profile -%}
    -pcmakeprof -reportstats \
  {% endif -%}
  {% if options.dtl -%}
    -dir={{ VCOMP_DIR }}/dtl_static \
    -enable_dynamic_tb \
  {% endif -%}

  {% if options.compile_args_file -%}
    -file {{ options.compile_args_file }} \
  {% endif -%}

  -file {{ bazel_compile_args }} \
  {% for define in additional_defines -%}
    +define+{{ define }} \
  {% endfor -%}
  {% if debug_mode == "default" -%}
    -debug_access+f \
  {% endif -%}
  {% if debug_mode == "waves" -%}
    {% if options.dtl -%}
      -kdb=common_elab \
    {% else -%}
      -kdb \
    {% endif -%}
    -debug_access+all+designer+simctrl \
    +define+UVM_VERDI_COMPWAVE \
  {% endif -%}
  {% if debug_mode == "gui" -%}
    -kdb \
    -debug_access+all+reverse \
  {% endif -%}
  {% if xprop_cmd -%}
    {{ xprop_cmd }} \
  {% endif -%}
  {% if cov_opts -%}
    {{ cov_opts }} \
  {% endif -%}
  -sml \
  -l {{ VCOMP_DIR }}/cmp.log \
  -o {{ VCOMP_DIR }}/simv
