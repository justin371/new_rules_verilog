#!/usr/bin/env bash

cd {{ bazel_runfiles_main }} && \

runmod -t vcs -- \
  -full64 \
  -Mdir={{ VCOMP_DIR }}/csrc \
  -Mlib={{ VCOMP_DIR }}/csrc \
  -p1800_macro_expansion \
  -file {{ bazel_compile_args }} \
  {% for define in additional_defines -%}
    +define+{{ define }} \
  {% endfor -%}
  {% if enable_debug_access == 0 -%}
    -debug_access+f \
  {% endif -%}
  {% if enable_debug_access == 1 -%}
    -kdb \
    -debug_access+all+designer+simctrl \
    +define+UVM_VERDI_COMPWAVE \
  {% endif -%}
  {% if enable_debug_access == 2 -%}
    +fsmdebug \
    -uvmlinedebug \
    -debug_access+reverse \
  {% endif -%}
  {% if cov_opts is not none -%}
    {{ cov_opts }} \
  {% endif -%}
  {% if enable_cdnvip == 1 -%}
	  -LDFLAGS -Wl,-E \
	  +define+DENALI_UVM +define+DENALI_SV_VCS -CFLAGS \'-DVCS=1\' \
    '${DENALI}'/ddvapi/sv/denaliMemSvIf.c \
    -CFLAGS \'-DVCS -DDENALI_SV_VCS=1 -I../ -I/usr/local/include -I'${DENALI}' -I'${DENALI}'/ddvapi -O2 -c\' \
	  -LDFLAGS \'-rdynamic '${DENALI}'/verilog/libcdnsv.so\' \
	  -LDFLAGS \'-rdynamic '${DENALI}'/lib/libviputil.so\' \
    -XVpiCbAutoRelease=libcdnsv.so \
    -P '${DENALI}'/verilog/cdnsv.tab \
  {% endif -%}
  -l {{ VCOMP_DIR }}/cmp.log \
  -o {{ VCOMP_DIR }}/simv
