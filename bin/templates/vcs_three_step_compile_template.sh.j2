#!/usr/bin/env bash
set -Eeuo pipefail

trap 'rc=$?; printf "ERROR: VCS three-step compile failed at line %s (exit %s): %s\n" "$LINENO" "$rc" "$BASH_COMMAND" >&2' ERR

mkdir -p \
  {{ (VCOMP_DIR ~ '/csrc')|shell_quote }} \
  {{ vcs_analysis_work_dir|shell_quote }}

printf 'WORK > DEFAULT\nDEFAULT : %s\n' \
  {{ vcs_analysis_work_dir|shell_quote }} \
  > {{ vcs_setup_file|shell_quote }}

export SYNOPSYS_SIM_SETUP={{ vcs_setup_file|shell_quote }}
: > {{ (VCOMP_DIR ~ '/cmp.log')|shell_quote }}
cd {{ bazel_runfiles_main|shell_quote }}

vlogan_args=()
while IFS= read -r vlogan_arg || [[ -n "${vlogan_arg}" ]]; do
  [[ -z "${vlogan_arg}" || "${vlogan_arg}" == \#* ]] && continue
  vlogan_args+=("${vlogan_arg}")
done < {{ vcs_vlogan_args|shell_quote }}

vlogan_include_args=()
vlogan_precompile_file_args=()
vlogan_project_file_args=()
while IFS=$'\t' read -r vcs_group vcs_flist || [[ -n "${vcs_group}${vcs_flist}" ]]; do
  [[ -z "${vcs_group}" || -z "${vcs_flist}" ]] && continue
  while IFS= read -r flist_line || [[ -n "${flist_line}" ]]; do
    [[ "${flist_line}" == +incdir+* ]] &&
      vlogan_include_args+=("${flist_line}")
  done < "${vcs_flist}"
  case "${vcs_group}" in
    precompile)
      vlogan_precompile_file_args+=(-file "${vcs_flist}")
      ;;
    project)
      vlogan_project_file_args+=(-file "${vcs_flist}")
      ;;
    *)
      printf 'ERROR: unknown VCS analysis group %s for %s\n' \
        "${vcs_group}" "${vcs_flist}" >&2
      exit 2
      ;;
  esac
done < {{ vcs_vlogan_filelists|shell_quote }}

vcs_home="$(
  {{ vcs_runner }} printenv VCS_HOME |
    tail -n 1
)"
uvm_sources=("${vcs_home%/}/etc/uvm-1.2/uvm_pkg.sv")
{% if debug_mode == "gui" -%}
  uvm_sources+=("${vcs_home%/}/etc/uvm-1.2/vcs/uvm_custom_install_vcs_recorder.sv")
{% endif -%}
for uvm_source in "${uvm_sources[@]}"; do
  [[ -f "${uvm_source}" ]] || {
    printf 'ERROR: VCS UVM source does not exist: %s\n' "${uvm_source}" >&2
    exit 2
  }
done

{{ vcs_runner }} vlogan \
  -full64 \
  -incr_vlogan \
  {{ vcs_incr_vlogan_ignore_env }} \
  "${vlogan_args[@]}" \
  {% for define in additional_defines -%}
    {{ ('+define+' ~ define)|shell_quote }} \
  {% endfor -%}
  {% if debug_mode == "gui" -%}
    +define+UVM_VERDI_COMPWAVE \
    +define+UVM_VCS_RECORD \
  {% endif -%}
  "${uvm_sources[@]}" \
  2>&1 | tee -a {{ (VCOMP_DIR ~ '/cmp.log')|shell_quote }}

run_vlogan_group() {
  local group_name="$1"
  shift
  (($# > 0)) || return 0
  printf 'VCS incremental analysis group: %s (%s filelists)\n' \
    "${group_name}" "$(($# / 2))" |
    tee -a {{ (VCOMP_DIR ~ '/cmp.log')|shell_quote }}
  {{ vcs_runner }} vlogan \
    -full64 \
    -incr_vlogan \
    {{ vcs_incr_vlogan_ignore_env }} \
    "${vlogan_args[@]}" \
    "${vlogan_include_args[@]}" \
    "$@" \
    {% for define in additional_defines -%}
      {{ ('+define+' ~ define)|shell_quote }} \
    {% endfor -%}
    {% if debug_mode == "gui" -%}
      +define+UVM_VERDI_COMPWAVE \
      +define+UVM_VCS_RECORD \
    {% endif -%}
    2>&1 | tee -a {{ (VCOMP_DIR ~ '/cmp.log')|shell_quote }}
}

run_vlogan_group precompile "${vlogan_precompile_file_args[@]}"
run_vlogan_group project "${vlogan_project_file_args[@]}"

{{ vcs_runner }} vcs \
  -full64 \
  -Mdir={{ (VCOMP_DIR ~ '/csrc')|shell_quote }} \
  -Mlib={{ (VCOMP_DIR ~ '/csrc')|shell_quote }} \
  {% if options.fgp is not none -%}
    -fgp \
  {% endif -%}
  {% if options.vcs_profile -%}
    -pcmakeprof -reportstats \
  {% endif -%}
  {% if partcomp_opts -%}
    {{ partcomp_opts }} \
  {% endif -%}
  {% if options.dtl -%}
    -enable_dynamic_tb \
  {% endif -%}
  {% if options.vso -%}
    -vso cso \
    -vso_opts buildname={{ vso_build_name|shell_quote }} \
    {% if options.vso_cbv -%}
      -vso_opts workdir={{ vso_workdir|shell_quote }} \
    {% endif -%}
  {% elif options.vso_ccex -%}
    -vso ccex \
  {% endif -%}
  -file {{ vcs_elab_args|shell_quote }} \
  {% if debug_mode == "waves" -%}
    {% if options.dtl -%}
      -kdb=common_elab \
    {% else -%}
      -kdb \
    {% endif -%}
    -debug_access \
  {% endif -%}
  {% if debug_mode == "gui" -%}
    -kdb \
    -debug_access+all+reverse \
    +vpi \
  {% endif -%}
  {% if options.xprop_was_explicit and xprop_cmd -%}
    {{ xprop_cmd }} \
  {% endif -%}
  {% if cov_opts -%}
    {{ cov_opts }} \
  {% endif -%}
  {% if options.smartlog -%}
    -sml \
  {% endif -%}
  -o {{ (VCOMP_DIR ~ '/simv')|shell_quote }} \
  2>&1 | tee -a {{ (VCOMP_DIR ~ '/cmp.log')|shell_quote }}
