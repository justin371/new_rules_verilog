# Cadence Xcelium requires $HOME to be set
build --action_env=HOME

# Keep local and CI Python behavior aligned with the supported Red Hat setup.
build --incompatible_use_python_toolchains=false
build --python_path=python3.12
build --action_env=PATH

# Lightelligence Specific
build --//:verilog_dv_unit_test_command="runmod -t xrun --"
build --//:verilog_rtl_cdc_test_command="runmod -t jg --"
build --//:verilog_rtl_unit_test_command="runmod -t xrun --"
build --//:verilog_rtl_lint_test_command="runmod -t xrun --"

# Optional Synopsys VCS/Verdi wrappers. Use with `--config=vcs`.
# Note: this only overrides tool wrapper commands. Targets still need
# `simulator = "VCS"` where simulator-specific behavior is required.
# Example: `bazel build --config=vcs //tests/vcs_filelist_validation:dv_tb_vcs`
build:vcs --//:verilog_rtl_lint_test_command_vcs="runmod vcs -- vcs"

#If true, Bazel tries to load external repositories from the Bzlmod system before looking into the WORKSPACE file
## Enable Bzlmod for every Bazel command
common --noenable_bzlmod
